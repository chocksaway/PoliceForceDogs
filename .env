# Local environment overrides for PoliceForceDogs
# Copy or edit values here for running locally. This file is gitignored.

# Full JDBC URL (must start with jdbc:). Leave commented to use application.properties default.
JDBC_URL=jdbc:h2:file:./target/police-force-dogs;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE

# Database user (default: sa)
JDBC_USER=sa

# Database password (default: empty)
JDBC_PASSWORD=

# Path to the H2 jar used by scripts/init-db.sh (optional override)
H2_JAR=lib/h2-2.3.232.jar

